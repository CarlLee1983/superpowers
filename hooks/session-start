#!/usr/bin/env bash
# SessionStart hook for superpowers plugin

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-superpowers content
using_superpowers_content=$(cat "${PLUGIN_ROOT}/skills/using-superpowers/SKILL.md" 2>&1 || echo "Error reading using-superpowers skill")
selector_content=$(cat "${PLUGIN_ROOT}/skills/selecting-workflow-mode/SKILL.md" 2>&1 || echo "Error reading selecting-workflow-mode skill")
risk_matrix_content=$(cat "${PLUGIN_ROOT}/skills/selecting-workflow-mode/references/risk-matrix.md" 2>&1 || echo "Error reading workflow risk matrix")

# Escape string for JSON embedding using bash parameter substitution.
# Each ${s//old/new} is a single C-level pass - orders of magnitude
# faster than the character-by-character loop this replaces.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_superpowers_escaped=$(escape_for_json "$using_superpowers_content")
selector_escaped=$(escape_for_json "$selector_content")
risk_matrix_escaped=$(escape_for_json "$risk_matrix_content")
session_context="<EXTREMELY_IMPORTANT>\nTask-entry sources are already loaded below. Before any Skill, Read, or task-specific tool, classify from these sources and output exactly one visible Mode: <lean|standard|strict> — <reason>. line. Do not invoke or reread the selector or matrix at task entry. If the request itself exposes strict risk under explicit lean/standard, warn immediately after the Mode line and before project inspection; the warning must be the very next assistant-visible content after the Mode line; no project tool, discovery, skill announcement, or other prose may precede it. CLAUDE EXPLICIT NON-STRICT OVERRIDE ENTRY: output exactly: Warning: <strict trigger> is strict-risk work. Retaining your explicit <lean|standard> override. End that assistant block immediately after the warning; do not paraphrase, explain, prefix, or suffix it. CLAUDE STANDARD ENTRY: after the Mode line and any required immediate override warning, output exactly: Approach: <...>. Files/components: <...>. Verification: <...>. Do not inspect the project or call another tool before this outline. Do not repeat it after inspection. After this task-entry sequence, use other relevant skills. CLAUDE EXPLICIT-SKILL INSPECTION: use Read only. Do not invoke ToolSearch, Agent, Bash, Glob, or Grep. Read a user-named or obvious likely source directly; if its path is unknown, ask for the path instead of searching. Before the first mutation, complete risk routing: explicit lean/standard plus strict evidence means warn and retain the override; automatic lean/standard plus strict evidence means canonical promotion and approval pause. A mutation before the standard outline is invalid. After discovery, never output a second Mode line, and discovered strict evidence must use the canonical Promoting to strict line followed by an approval pause. CLAUDE PRE-PROMOTION INSPECTION: use Read only. Do not invoke ToolSearch, Agent, Bash, Glob, or Grep. Read the user-named source and a likely same-directory consumer directly; if no consumer path can be identified, pause instead of searching. CLAUDE PROMOTION ENTRY: output exactly: Promoting to strict — inspection found <source> defines <field> consumed by <consumer> as part of <strict surface>; <change> would <consequence>. Then pause for approval without mutation.\n\n**using-superpowers source:**\n\n${using_superpowers_escaped}\n\n**selecting-workflow-mode source:**\n\n${selector_escaped}\n\n**workflow risk-matrix source:**\n\n${risk_matrix_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Cursor hooks expect additional_context (snake_case).
# Claude Code hooks expect hookSpecificOutput.additionalContext (nested).
# Copilot CLI (v1.0.11+) and others expect additionalContext (top-level, SDK standard).
# Claude Code reads BOTH additional_context and hookSpecificOutput without
# deduplication, so we must emit only the field the current platform consumes.
#
# Uses printf instead of heredoc to work around bash 5.3+ heredoc hang.
# See: https://github.com/obra/superpowers/issues/571
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  # Cursor sets CURSOR_PLUGIN_ROOT (may also set CLAUDE_PLUGIN_ROOT)
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context" | cat
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  # Claude Code sets CLAUDE_PLUGIN_ROOT without COPILOT_CLI
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context" | cat
else
  # Copilot CLI (sets COPILOT_CLI=1) or unknown platform — SDK standard format
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context" | cat
fi

exit 0
